# Copy this file to .env.local and adjust for your machine, then rebuild
# (npm run build) — this value is baked in at build time.
# Base URL the BROWSER uses to reach the API.
# Production: the frontend's own origin (Next.js proxies /api/* to the
# backend locally), so use the dev machine's LAN IP with no port when
# serving on port 80.
NEXT_PUBLIC_API_URL=http://10.135.5.15
